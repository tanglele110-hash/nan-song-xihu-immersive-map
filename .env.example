# apps/api runtime
HOST=127.0.0.1
PORT=4174
LOG_LEVEL=info
CONTENT_CACHE_TTL_MS=1000
CONTENT_ROOT=.

# Frontend API mode is explicit. Use the Vite proxy with:
# http://127.0.0.1:5173/app/index.html?api=1
# Or point at a deployed API:
# http://127.0.0.1:5173/app/index.html?api=1&apiBase=http://127.0.0.1:4174
